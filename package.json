{
  "name": "pratyayprofile",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "bun run build && wrangler dev",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "gen": "wrangler types",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@fortawesome/svelte-fontawesome": "^0.2.4",
    "@sveltejs/enhanced-img": "^0.10.4",
    "eslint-plugin-svelte": "^3.17.0",
    "mdsvex": "^0.12.7",
    "pocketbase": "^0.26.8",
    "svelte-exmarkdown": "^5.0.2",
    "typescript-eslint": "^8.58.2",
    "vite-plugin-oxlint": "^2.0.1",
    "vite-plugin-robots": "^1.0.5",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^0.577.0",
    "@ox-content/vite-plugin": "0.17.0",
    "@ox-content/vite-plugin-svelte": "^0.17.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "globals": "^17.5.0",
    "mode-watcher": "^1.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.60.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "wrangler": "^4.83.0"
  }
